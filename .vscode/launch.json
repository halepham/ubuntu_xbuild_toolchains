{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    // For launch.json reference, visit https://code.visualstudio.com/docs/cpp/launch-json-reference
    "version": "0.2.0",
    "configurations": [
        {
            // CMake GDB Launch, refer to https://github.com/microsoft/vscode-cmake-tools/blob/main/docs/debug-launch.md
            "name": "GDB for ROS2 Run",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/install/${config:NODE_PACKAGE_NAME}/lib/${config:NODE_PACKAGE_NAME}/${config:NODE_EXECUTABLE_NAME}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Set sysroot to local ARM libraries",
                    "text": "set sysroot ${config:TARGET_LOCAL_SYSROOT}",
                },
                {
                    "description": "Set source directories searched",
                    "text": "dir ${config:TARGET_LOCAL_SYSROOT}"
                },
                {
                    "description": "Map build system source path to local source path",
                    "text": "set substitute-path /usr/src ${config:TARGET_LOCAL_SYSROOT}/usr/src"
                },
                {
                    "description": "Disable debuginfod source auto-download",
                    "text": "set debuginfod enabled off",
                    "ignoreFailures": true
                },
                {
                    "description": "Allow pending breakpoints (main may not be loaded yet)",
                    "text": "set breakpoint pending on",
                    "ignoreFailures": true
                },
                {
                    "description": "Stop once at main()",
                    "text": "tbreak main",
                    "ignoreFailures": true
                },
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "miDebuggerPath": "${config:HOST_GDB_PATH}",
            "miDebuggerServerAddress": "${config:TARGET_IP}:${config:TARGET_GDB_PORT}",
            "targetArchitecture": "arm",
            "additionalSOLibSearchPath": "${config:TARGET_LOCAL_SYSROOT}/lib",
            "preLaunchTask": "ROS2: Debug Run (GDB)"
        },
        {
            "name": "GDB for ROS2 Launch",
